<div class="max-w-2xl mx-auto">
  <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6">
    <p class="text-sm text-amber-800 font-medium">Simulador de pagos (desarrollo local)</p>
    <p class="text-xs text-amber-600 mt-1">En producción, el usuario sería redirigido a la pasarela de Bancard.</p>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 p-8 text-center">
    <h1 class="text-2xl font-bold text-gray-900">Procesando pago...</h1>
    <p class="mt-2 text-gray-500">Pago #<%= @payment.id %> — Plan <%= @payment.plan_label %> — Gs. <%= number_with_delimiter(@payment.amount) %></p>

    <div class="mt-8 border-t border-gray-100 pt-8">
      <p class="text-sm text-gray-600 mb-6">Seleccioná el resultado de la simulación:</p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <%= link_to success_payment_simulators_path(payment_id: @payment.id),
            class: "inline-flex items-center justify-center px-8 py-3 rounded-lg bg-green-600 text-white font-semibold hover:bg-green-700 transition" do %>
          <span class="mr-2">&#10003;</span> Simular pago exitoso
        <% end %>

        <%= link_to fail_payment_simulators_path(payment_id: @payment.id),
            class: "inline-flex items-center justify-center px-8 py-3 rounded-lg bg-red-600 text-white font-semibold hover:bg-red-700 transition" do %>
          <span class="mr-2">&#10007;</span> Simular pago fallido
        <% end %>
      </div>
    </div>
  </div>
</div>
