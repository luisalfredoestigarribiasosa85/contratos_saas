<div class="max-w-2xl mx-auto text-center">
  <div class="bg-green-50 border border-green-200 rounded-xl p-8">
    <div class="text-green-600 text-5xl mb-4">&#10003;</div>
    <h1 class="text-2xl font-bold text-green-800">Pago simulado exitosamente</h1>
    <p class="mt-2 text-green-700">Tu suscripción fue actualizada al plan <strong><%= @payment.plan_label %></strong>.</p>

    <div class="mt-6 bg-white rounded-lg border border-green-100 p-4 text-left">
      <h3 class="text-sm font-semibold text-gray-700 mb-3">Detalles del pago simulado</h3>
      <dl class="space-y-2 text-sm">
        <div class="flex justify-between">
          <dt class="text-gray-500">ID de pago:</dt>
          <dd class="font-mono text-gray-900">#<%= @payment.id %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500">Plan:</dt>
          <dd class="font-semibold text-gray-900"><%= @payment.plan_label %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500">Monto:</dt>
          <dd class="font-semibold text-gray-900">Gs. <%= number_with_delimiter(@payment.amount) %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500">Estado:</dt>
          <dd><span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Exitoso</span></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500">Válido hasta:</dt>
          <dd class="text-gray-900"><%= @subscription.expires_at ? l(@subscription.expires_at.to_date, format: :long) : "Sin vencimiento" %></dd>
        </div>
      </dl>
    </div>

    <div class="mt-6 bg-amber-50 border border-amber-200 rounded-lg p-3">
      <p class="text-xs text-amber-700">Simulador de desarrollo. En producción este flujo será procesado por Bancard.</p>
    </div>

    <div class="mt-6 space-x-4">
      <%= link_to "Ir al Dashboard", dashboard_path, class: "inline-flex px-6 py-2 rounded-lg bg-indigo-600 text-white font-semibold hover:bg-indigo-700" %>
      <%= link_to "Ver mi plan", account_plan_path, class: "inline-flex px-6 py-2 rounded-lg bg-white border border-gray-300 text-gray-700 font-semibold hover:bg-gray-50" %>
    </div>
  </div>
</div>
