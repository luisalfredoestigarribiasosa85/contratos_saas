<div class="mb-6">
  <%= link_to "← Volver a mi plan", account_plan_path, class: "text-sm text-indigo-600 hover:text-indigo-800" %>
</div>

<div class="max-w-2xl mx-auto">
  <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6">
    <p class="text-sm text-amber-800 font-medium">Modo simulador de pagos (desarrollo local)</p>
    <p class="text-xs text-amber-600 mt-1">Este flujo simula el proceso de pago. Será reemplazado por Bancard en producción.</p>
  </div>

  <h1 class="text-2xl font-bold text-gray-900">Simular pago</h1>
  <p class="mt-1 text-sm text-gray-500">Seleccioná un plan para simular el proceso de pago.</p>

  <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-6">
    <%# Pro Plan %>
    <div class="bg-white rounded-lg border-2 <%= @plan == 'pro' ? 'border-indigo-600' : 'border-gray-200' %> p-6">
      <h3 class="text-lg font-bold text-gray-900">Pro</h3>
      <p class="mt-1 text-2xl font-extrabold text-gray-900">
        Gs. 39.000 <span class="text-sm font-normal text-gray-500">/mes</span>
      </p>
      <ul class="mt-4 space-y-2">
        <% ["Contratos ilimitados", "Todas las plantillas", "PDF sin marca de agua", "Historial completo"].each do |feature| %>
          <li class="flex items-center text-sm text-gray-600">
            <span class="text-green-500 mr-2">&#10003;</span> <%= feature %>
          </li>
        <% end %>
      </ul>
      <div class="mt-6">
        <%= form_with url: payment_simulators_path, method: :post, class: "inline" do |f| %>
          <%= f.hidden_field :plan, value: "pro" %>
          <%= f.submit "Simular pago Pro",
              class: "w-full text-center px-4 py-2 rounded-lg bg-indigo-600 text-white font-semibold hover:bg-indigo-700 cursor-pointer" %>
        <% end %>
      </div>
    </div>

    <%# Business Plan %>
    <div class="bg-white rounded-lg border-2 <%= @plan == 'business' ? 'border-indigo-600' : 'border-gray-200' %> p-6">
      <h3 class="text-lg font-bold text-gray-900">Business</h3>
      <p class="mt-1 text-2xl font-extrabold text-gray-900">
        Gs. 120.000 <span class="text-sm font-normal text-gray-500">/mes</span>
      </p>
      <ul class="mt-4 space-y-2">
        <% ["Todo lo de Pro", "Soporte prioritario", "Plantillas personalizadas", "Exportación masiva"].each do |feature| %>
          <li class="flex items-center text-sm text-gray-600">
            <span class="text-green-500 mr-2">&#10003;</span> <%= feature %>
          </li>
        <% end %>
      </ul>
      <div class="mt-6">
        <%= form_with url: payment_simulators_path, method: :post, class: "inline" do |f| %>
          <%= f.hidden_field :plan, value: "business" %>
          <%= f.submit "Simular pago Business",
              class: "w-full text-center px-4 py-2 rounded-lg bg-indigo-600 text-white font-semibold hover:bg-indigo-700 cursor-pointer" %>
        <% end %>
      </div>
    </div>
  </div>
</div>
