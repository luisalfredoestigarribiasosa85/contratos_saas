<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Header -->
  <div class="mb-8">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Plantillas Personalizadas</h1>
        <p class="mt-1 text-sm text-gray-500">Gestiona las plantillas personalizadas de tu empresa</p>
      </div>
      <%= link_to "Nueva Plantilla", new_custom_template_path, class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700" %>
    </div>
  </div>

  <!-- Templates Grid -->
  <% if @custom_templates.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @custom_templates.each do |template| %>
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 hover:shadow-md transition-shadow">
          <div class="flex items-start justify-between mb-4">
            <div class="flex-1">
              <h3 class="text-lg font-medium text-gray-900 mb-2"><%= template.name %></h3>
              <p class="text-sm text-gray-500 mb-3"><%= template.description %></p>
              <div class="flex items-center text-xs text-gray-400">
                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                Basado en: <%= template.contract_template.name %>
              </div>
            </div>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800">
              <%= template.contract_template.category %>
            </span>
          </div>
          
          <div class="flex items-center justify-between pt-4 border-t border-gray-200">
            <div class="flex space-x-2">
              <%= link_to "Editar", edit_custom_template_path(template), class: "inline-flex items-center px-3 py-1 border border-gray-300 shadow-sm text-xs font-medium rounded text-gray-700 bg-white hover:bg-gray-50" %>
              <%= link_to "Usar", new_contract_path(custom_template_id: template.id), class: "inline-flex items-center px-3 py-1 border border-transparent shadow-sm text-xs font-medium rounded text-white bg-green-600 hover:bg-green-700" %>
            </div>
            <%= link_to "Eliminar", custom_template_path(template), 
                data: { turbo_method: :delete, turbo_confirm: "¿Estás seguro de que quieres eliminar esta plantilla?" }, 
                class: "text-red-600 hover:text-red-800 text-xs" %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <!-- Empty State -->
    <div class="text-center py-12">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      <h3 class="mt-2 text-sm font-medium text-gray-900">No hay plantillas personalizadas</h3>
      <p class="mt-1 text-sm text-gray-500">Crea tu primera plantilla personalizada para tu equipo.</p>
      <div class="mt-6">
        <%= link_to "Crear Plantilla", new_custom_template_path, class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700" %>
      </div>
    </div>
  <% end %>

  <!-- Available Base Templates -->
  <div class="mt-12">
    <h2 class="text-lg font-medium text-gray-900 mb-4">Plantillas Base Disponibles</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      <% @contract_templates.each do |template| %>
        <div class="border border-gray-200 rounded-lg p-4 hover:border-indigo-300 transition-colors cursor-pointer" onclick="window.location.href='<%= new_custom_template_path(contract_template_id: template.id) %>'">
          <h4 class="font-medium text-gray-900 mb-1"><%= template.name %></h4>
          <p class="text-xs text-gray-500 mb-2"><%= template.description %></p>
          <div class="flex items-center justify-between">
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-800">
              <%= template.category %>
            </span>
            <span class="text-xs text-indigo-600">Personalizar</span>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
