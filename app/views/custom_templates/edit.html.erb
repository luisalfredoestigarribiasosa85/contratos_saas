<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Editar Plantilla Personalizada</h1>
    <p class="mt-1 text-sm text-gray-500">Edita tu plantilla personalizada</p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Main Form Column -->
    <div class="lg:col-span-2">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <%= form_with(model: @custom_template, local: true, class: "space-y-6") do |form| %>
          <% if @custom_template.errors.any? %>
            <div class="rounded-md bg-red-50 p-4">
              <div class="flex">
                <div class="flex-shrink-0">
                  <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                  </svg>
                </div>
                <div class="ml-3">
                  <h3 class="text-sm font-medium text-red-800">
                    Hay <%= pluralize(@custom_template.errors.count, "error") %>
                  </h3>
                  <div class="mt-2 text-sm text-red-700">
                    <ul class="list-disc list-inside space-y-1">
                      <% @custom_template.errors.full_messages.each do |message| %>
                        <li><%= message %></li>
                      <% end %>
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          <% end %>

          <!-- Contract Template Selection -->
          <div>
            <%= form.label :contract_template_id, "Plantilla Base", class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= form.select :contract_template_id, 
                  options_from_collection_for_select(@contract_templates, :id, :name, @custom_template.contract_template_id),
                  { prompt: "Selecciona una plantilla base" },
                  { class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md" } %>
            </div>
            <p class="mt-1 text-xs text-gray-500">Selecciona una plantilla base para personalizar</p>
          </div>

          <!-- Template Name -->
          <div>
            <%= form.label :name, "Nombre de la Plantilla", class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= form.text_field :name, class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md", placeholder: "Contrato de Alquiler Personalizado" %>
            </div>
          </div>

          <!-- Description -->
          <div>
            <%= form.label :description, "Descripción", class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= form.text_area :description, rows: 3, class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md", placeholder: "Contrato de alquiler adaptado a las necesidades de nuestra empresa..." %>
            </div>
          </div>

          <!-- Template Body -->
          <div>
            <%= form.label :body, "Contenido de la Plantilla", class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= form.text_area :body, rows: 20, class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md font-mono text-sm", placeholder: "Escribe aquí el contenido de tu plantilla..." %>
            </div>
            <p class="mt-1 text-xs text-gray-500">
              Usa {{placeholder}} para los campos que serán reemplazados. Ej: {{nombre_cliente}}
            </p>
          </div>

          <!-- Field Configuration -->
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="text-sm font-medium text-gray-900 mb-3">Configuración de Campos</h3>
            <p class="text-xs text-gray-500 mb-3">Define las etiquetas y ayudas para los placeholders de tu plantilla</p>
            
            <div id="field-config-container" class="space-y-3">
              <!-- Fields will be dynamically added here based on placeholders in the body -->
            </div>
          </div>

          <!-- Actions -->
          <div class="flex justify-end space-x-3 pt-4 border-t border-gray-200">
            <%= link_to "Cancelar", custom_templates_path, class: "bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50" %>
            <%= form.submit "Actualizar Plantilla", class: "bg-indigo-600 py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Right Sidebar - Variables Help -->
    <div class="lg:col-span-1">
      <div id="variables-help" class="hidden sticky top-6">
        <div class="bg-blue-50 border border-blue-200 rounded-lg">
          <div class="p-4 border-b border-blue-200">
            <div class="flex items-center">
              <svg class="h-5 w-5 text-blue-400 mr-2" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
              </svg>
              <div>
                <h3 class="text-sm font-medium text-blue-800">Variables Disponibles</h3>
                <p class="text-xs text-blue-600 mt-0.5">Haz clic para insertar</p>
              </div>
            </div>
          </div>
          
          <div id="variables-list" class="max-h-80 overflow-y-auto">
            <!-- Variables will be populated here dynamically -->
          </div>
          
          <div class="p-3 bg-blue-100 border-t border-blue-200">
            <p class="text-xs text-blue-700">
              <strong>Tip:</strong> Las variables se insertan donde tienes el cursor
            </p>
          </div>
        </div>

        <!-- Quick Tips -->
        <div class="mt-4 bg-gray-50 border border-gray-200 rounded-lg p-4">
          <h4 class="text-sm font-medium text-gray-900 mb-3">Consejos Rápidos</h4>
          <ul class="space-y-2 text-xs text-gray-600">
            <li class="flex items-start">
              <svg class="h-4 w-4 text-green-500 mr-1 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span>Usa siempre llaves dobles: {{variable}}</span>
            </li>
            <li class="flex items-start">
              <svg class="h-4 w-4 text-green-500 mr-1 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span>Sin espacios ni caracteres especiales</span>
            </li>
            <li class="flex items-start">
              <svg class="h-4 w-4 text-green-500 mr-1 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span>Usa guion bajo: {{nombre_cliente}}</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Empty State when no template selected -->
      <div id="no-template-selected" class="sticky top-6">
        <div class="bg-gray-50 border border-gray-200 rounded-lg p-6 text-center">
          <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          <h3 class="mt-2 text-sm font-medium text-gray-900">Selecciona una Plantilla Base</h3>
          <p class="mt-1 text-xs text-gray-500">Para ver las variables disponibles, primero selecciona una plantilla base.</p>
        </div>
      </div>
    </div>
  </div>
</div>

