        { name: 'mes', label: 'Mes', hint: 'Ingrese el nombre del mes (ej: Marzo)' },
        { name: 'anio', label: 'Año', hint: 'Ingrese el año con 4 dígitos (ej: 2026)' },
        { name: 'nombre_vendedor', label: 'Nombre del Vendedor', hint: 'Nombre completo del vendedor' },
        { name: 'ci_vendedor', label: 'Cédula del Vendedor', hint: 'Sin puntos (ej: 1234567)' },
        { name: 'domicilio_vendedor', label: 'Domicilio del Vendedor', hint: 'Dirección del vendedor' },
        { name: 'nombre_comprador', label: 'Nombre del Comprador', hint: 'Nombre completo del comprador' },
        { name: 'ci_comprador', label: 'Cédula del Comprador', hint: 'Sin puntos (ej: 1234567)' },
        { name: 'domicilio_comprador', label: 'Domicilio del Comprador', hint: 'Dirección del comprador' },
        { name: 'direccion_inmueble', label: 'Dirección del Inmueble', hint: 'Dirección completa del inmueble' },
        { name: 'numero_finca', label: 'Número de Finca', hint: 'Número de finca registral' },
        { name: 'distrito', label: 'Distrito', hint: 'Distrito donde se ubica el inmueble' },
        { name: 'precio_total', label: 'Precio Total', hint: 'Solo números, sin puntos ni comas (ej: 150000000)' },
        { name: 'forma_pago', label: 'Forma de Pago', hint: 'Ej: contado, financiamiento bancario' },
        { name: 'fecha_entrega', label: 'Fecha de Entrega', hint: 'Formato: dd/mm/aaaa (ej: 01/02/2027)' },
        { name: 'responsable_gastos', label: 'Responsable de Gastos', hint: 'Quién paga los gastos de escrituración (ej: comprador, vendedor, mitad y mitad)' }
      ]
    };
    
    function extractPlaceholders(text) {
      const matches = text.match(/\{\{(\w+)\}\}/g);
      if (!matches) return [];
      return matches.map(match => match.slice(2, -2));
    }
    
    function updateVariablesHelp() {
      const noTemplateSelected = document.getElementById('no-template-selected');
      
      if (!templateSelect || !templateSelect.value) {
        variablesHelp.classList.add('hidden');
        if (noTemplateSelected) noTemplateSelected.classList.remove('hidden');
        return;
      }
      
      const selectedOption = templateSelect.options[templateSelect.selectedIndex];
      const templateName = selectedOption ? selectedOption.text : '';
      const variables = templateVariables[templateName] || [];
      
      if (variables.length === 0) {
        variablesHelp.classList.add('hidden');
        if (noTemplateSelected) noTemplateSelected.classList.remove('hidden');
        return;
      }
      
      variablesHelp.style.display = 'block';
      variablesHelp.classList.remove('hidden');
      if (noTemplateSelected) noTemplateSelected.classList.add('hidden');
      variablesList.innerHTML = '';
      
      variables.forEach(variable => {
        const variableDiv = document.createElement('div');
        variableDiv.className = 'border-b border-blue-100 last:border-b-0 hover:bg-blue-100 transition-colors cursor-pointer';
        variableDiv.innerHTML = `
          <div class="p-3">
            <div class="flex items-start justify-between">
              <div class="flex-1 min-w-0">
                <div class="flex items-center space-x-2 mb-1">
                  <code class="bg-blue-100 text-blue-800 px-1.5 py-0.5 rounded text-xs font-mono flex-shrink-0">
                    {{${variable.name}}}
                  </code>
                  <span class="text-sm font-medium text-gray-900 truncate">${variable.label}</span>
                </div>
                <p class="text-xs text-gray-500 line-clamp-2">${variable.hint}</p>
              </div>
              <button type="button" class="insert-variable-btn text-blue-600 hover:text-blue-800 text-xs font-medium bg-white border border-blue-300 px-2 py-1 rounded hover:bg-blue-50 ml-2 flex-shrink-0" data-variable="${variable.name}">
                Insertar
              </button>
            </div>
          </div>
        `;
        variablesList.appendChild(variableDiv);
      });
      
      document.querySelectorAll('.insert-variable-btn').forEach(btn => {
        btn.addEventListener('click', function() {
          const variable = this.dataset.variable;
          const cursorPos = bodyTextarea.selectionStart;
          const textBefore = bodyTextarea.value.substring(0, cursorPos);
          const textAfter = bodyTextarea.value.substring(cursorPos);
          
          bodyTextarea.value = textBefore + `{{${variable}}}` + textAfter;
          bodyTextarea.focus();
          bodyTextarea.setSelectionRange(cursorPos + variable.length + 4, cursorPos + variable.length + 4);
          
          updateFieldConfig();
        });
      });
    }
    
    function updateFieldConfig() {
      const body = bodyTextarea.value;
      const placeholders = extractPlaceholders(body);
      
      fieldConfigContainer.innerHTML = '';
      
      if (placeholders.length === 0) {
        fieldConfigContainer.innerHTML = '<p class="text-sm text-gray-500">No se encontraron placeholders en el contenido</p>';
        return;
      }
      
      placeholders.forEach(placeholder => {
        const fieldDiv = document.createElement('div');
        fieldDiv.className = 'grid grid-cols-1 md:grid-cols-3 gap-3 items-center';
        fieldDiv.innerHTML = `
          <div class="text-sm font-medium text-gray-700">
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-800">
              {{${placeholder}}}
            </span>
          </div>
          <input type="text" name="custom_template[field_config][${placeholder}][label]" 
                 placeholder="Etiqueta" 
                 class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md"
                 value="${placeholder.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase())}">
          <input type="text" name="custom_template[field_config][${placeholder}][hint]" 
                 placeholder="Ayuda (opcional)" 
                 class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md">
        `;
        fieldConfigContainer.appendChild(fieldDiv);
      });
    }
    
    // Event listeners
    if (templateSelect) {
      templateSelect.addEventListener('change', updateVariablesHelp);
      templateSelect.addEventListener('input', updateVariablesHelp);
    }
    
    if (bodyTextarea) {
      bodyTextarea.addEventListener('input', updateFieldConfig);
    }
    
    // Initial calls with multiple delays to ensure DOM is ready after navigation
    const initializeApp = () => {
      // Re-get elements in case they weren't available initially
      const templateSelect = document.getElementById('custom_template_contract_template_id');
      const variablesHelp = document.getElementById('variables-help');
      const variablesList = document.getElementById('variables-list');
      const fieldConfigContainer = document.getElementById('field-config-container');
      const bodyTextarea = document.getElementById('custom_template_body');
      const noTemplateSelected = document.getElementById('no-template-selected');
      
      if (templateSelect && variablesHelp && variablesList && fieldConfigContainer && bodyTextarea) {
        updateVariablesHelp();
        updateFieldConfig();
      } else {
        // Try again after a short delay
        setTimeout(initializeApp, 100);
      }
    };
    
    // Start initialization
    setTimeout(initializeApp, 200);
    
    // Fallback: try again when DOM is fully loaded
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initializeApp);
    }
  });
</script>
