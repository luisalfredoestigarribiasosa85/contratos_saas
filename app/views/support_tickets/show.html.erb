<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-6">
    <%= link_to "← Volver a Tickets", support_tickets_path, class: "text-sm text-indigo-600 hover:text-indigo-900" %>
  </div>

  <div class="bg-white shadow-sm rounded-lg">
    <div class="px-4 py-5 sm:p-6">
      <div class="flex items-start justify-between mb-6">
        <div class="flex-1">
          <h1 class="text-2xl font-bold text-gray-900 mb-2"><%= @support_ticket.subject %></h1>
          <div class="flex items-center space-x-3">
            <% priority_class = case @support_ticket.priority
                                 when 'urgent' then 'bg-red-100 text-red-800'
                                 when 'high' then 'bg-orange-100 text-orange-800'
                                 when 'normal' then 'bg-blue-100 text-blue-800'
                                 when 'low' then 'bg-gray-100 text-gray-800'
                                 else 'bg-gray-100 text-gray-800'
                                 end %>
            <% status_class = case @support_ticket.status
                              when 'open' then 'bg-green-100 text-green-800'
                              when 'in_progress' then 'bg-yellow-100 text-yellow-800'
                              when 'resolved' then 'bg-blue-100 text-blue-800'
                              when 'closed' then 'bg-gray-100 text-gray-800'
                              else 'bg-gray-100 text-gray-800'
                              end %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= priority_class %>">
              Prioridad: <%= @support_ticket.priority.upcase %>
            </span>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= status_class %>">
              Estado: <%= @support_ticket.status.gsub('_', ' ').upcase %>
            </span>
          </div>
        </div>
        <div class="text-sm text-gray-500">
          Creado: <%= @support_ticket.created_at.strftime('%d/%m/%Y %H:%M') %>
        </div>
      </div>

      <div class="border-t border-gray-200 pt-6">
        <h3 class="text-sm font-medium text-gray-900 mb-2">Descripción</h3>
        <p class="text-gray-700 whitespace-pre-wrap"><%= @support_ticket.description %></p>
      </div>

      <% if @support_ticket.user.business? %>
        <div class="mt-6 bg-green-50 border border-green-200 rounded-md p-4">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-green-400" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="ml-3">
              <p class="text-sm text-green-800">
                <strong>Soporte Prioritario Business:</strong> Este ticket tiene prioridad alta y será atendido antes que los tickets estándar.
              </p>
            </div>
          </div>
        </div>
      <% end %>

      <!-- Replies -->
      <div class="mt-6 border-t border-gray-200 pt-6">
        <h3 class="text-sm font-medium text-gray-900 mb-4">Historial de Respuestas (<%= @support_ticket.reply_count %>)</h3>
        
        <% if @support_ticket.ticket_replies.any? %>
          <div class="space-y-4">
            <% @support_ticket.ticket_replies.order(:created_at).each do |reply| %>
              <div class="flex items-start space-x-3">
                <div class="flex-shrink-0">
                  <div class="h-10 w-10 rounded-full <%= reply.user.admin? ? 'bg-purple-100' : 'bg-indigo-100' %> flex items-center justify-center">
                    <span class="<%= reply.user.admin? ? 'text-purple-600' : 'text-indigo-600' %> font-medium"><%= reply.user.email.first.upcase %></span>
                  </div>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center space-x-2 mb-1">
                    <% if reply.user.admin? %>
                      <span class="text-sm font-medium text-gray-900">Soporte Técnico</span>
                      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-purple-100 text-purple-800">Admin</span>
                    <% else %>
                      <span class="text-sm font-medium text-gray-900"><%= reply.user.email %></span>
                      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-indigo-100 text-indigo-800">Tú</span>
                    <% end %>
                    <span class="text-xs text-gray-500"><%= reply.created_at.strftime('%d/%m/%Y %H:%M') %></span>
                  </div>
                  <div class="bg-gray-50 rounded-lg p-3">
                    <p class="text-sm text-gray-700 whitespace-pre-wrap"><%= reply.message %></p>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-gray-500">No hay respuestas aún. Te notificaremos cuando el soporte responda.</p>
        <% end %>
      </div>

      <!-- Reply Form (only if ticket is not closed) -->
      <% unless @support_ticket.closed? %>
        <div class="mt-6 border-t border-gray-200 pt-6">
          <h3 class="text-sm font-medium text-gray-900 mb-3">Responder</h3>
          <%= form_with(model: [@support_ticket, @ticket_reply], url: create_reply_support_ticket_path(@support_ticket), method: :post, local: true, class: "space-y-4") do |form| %>
            <div>
              <%= form.text_area :message, rows: 4, class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md", placeholder: "Escribe tu respuesta..." %>
            </div>
            <div class="flex justify-end">
              <%= form.submit "Enviar Respuesta", class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700" %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
