<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Header -->
  <div class="mb-8">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Tickets de Soporte</h1>
        <p class="mt-1 text-sm text-gray-500">Gestiona tus tickets de soporte prioritario</p>
      </div>
      <%= link_to "Nuevo Ticket", new_support_ticket_path, class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 whitespace-nowrap" %>
    </div>
  </div>

  <!-- Priority Notice -->
  <div class="bg-green-50 border border-green-200 rounded-md p-4 mb-6">
    <div class="flex items-start">
      <div class="flex-shrink-0">
        <svg class="h-5 w-5 text-green-400" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
        </svg>
      </div>
      <div class="ml-3">
        <p class="text-sm text-green-800">
          <strong>Soporte Prioritario Business:</strong> Todos tus tickets tienen prioridad alta y serán atendidos antes que los tickets estándar.
        </p>
      </div>
    </div>
  </div>

  <!-- Tickets List -->
  <% if @support_tickets.any? %>
    <div class="bg-white shadow-sm rounded-lg overflow-hidden">
      <ul class="divide-y divide-gray-200">
        <% @support_tickets.each do |ticket| %>
          <% priority_class = case ticket.priority
                               when 'urgent' then 'bg-red-100 text-red-800'
                               when 'high' then 'bg-orange-100 text-orange-800'
                               when 'normal' then 'bg-blue-100 text-blue-800'
                               else 'bg-gray-100 text-gray-800'
                               end %>
          <% status_class = case ticket.status
                            when 'open' then 'bg-green-100 text-green-800'
                            when 'in_progress' then 'bg-yellow-100 text-yellow-800'
                            when 'resolved' then 'bg-blue-100 text-blue-800'
                            when 'closed' then 'bg-gray-100 text-gray-800'
                            else 'bg-gray-100 text-gray-800'
                            end %>
          <li class="p-4 sm:p-6 hover:bg-gray-50">
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
              <div class="flex-1 min-w-0">
                <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-3">
                  <%= link_to ticket.subject, support_ticket_path(ticket), class: "text-sm font-medium text-indigo-600 hover:text-indigo-900 truncate" %>
                  <div class="flex space-x-2">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= priority_class %>">
                      <%= ticket.priority.upcase %>
                    </span>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= status_class %>">
                      <%= ticket.status.gsub('_', ' ').upcase %>
                    </span>
                  </div>
                </div>
                <div class="mt-2 flex items-center text-sm text-gray-500">
                  <svg class="flex-shrink-0 mr-1.5 h-5 w-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" />
                  </svg>
                  Creado: <%= ticket.created_at.strftime('%d/%m/%Y %H:%M') %>
                </div>
                <div class="mt-1">
                  <p class="text-sm text-gray-600 line-clamp-2"><%= ticket.description.truncate(100) %></p>
                </div>
              </div>
              <div class="flex-shrink-0">
                <%= link_to "Ver", support_ticket_path(ticket), class: "inline-flex items-center px-3 py-1.5 border border-gray-300 shadow-sm text-xs font-medium rounded text-gray-700 bg-white hover:bg-gray-50" %>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  <% else %>
    <!-- Empty State -->
    <div class="text-center py-12">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <h3 class="mt-2 text-sm font-medium text-gray-900">No hay tickets de soporte</h3>
      <p class="mt-1 text-sm text-gray-500">Crea tu primer ticket de soporte prioritario.</p>
      <div class="mt-6">
        <%= link_to "Crear Ticket", new_support_ticket_path, class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700" %>
      </div>
    </div>
  <% end %>
</div>
