<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Nuevo Ticket de Soporte</h1>
    <p class="mt-1 text-sm text-gray-500">Crea un ticket de soporte para recibir ayuda</p>
  </div>

  <% if current_user.business? %>
    <div class="bg-green-50 border border-green-200 rounded-md p-4 mb-6">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-green-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <p class="text-sm text-green-800">
            <strong>Soporte Prioritario Business:</strong> Tu ticket tendrá prioridad alta y será atendido antes que los tickets estándar.
          </p>
        </div>
      </div>
    </div>
  <% end %>

  <div class="bg-white shadow-sm rounded-lg">
    <%= form_with(model: @support_ticket, local: true, class: "px-4 py-5 sm:p-6") do |form| %>
      <% if @support_ticket.errors.any? %>
        <div class="rounded-md bg-red-50 p-4 mb-4">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="ml-3">
              <h3 class="text-sm font-medium text-red-800">
                Hay <%= pluralize(@support_ticket.errors.count, "error") %>
              </h3>
              <div class="mt-2 text-sm text-red-700">
                <ul class="list-disc list-inside space-y-1">
                  <% @support_ticket.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            </div>
          </div>
        </div>
      <% end %>

      <div class="space-y-6">
        <div>
          <%= form.label :subject, "Asunto", class: "block text-sm font-medium text-gray-700" %>
          <div class="mt-1">
            <%= form.text_field :subject, class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md", placeholder: "Describe brevemente tu problema" %>
          </div>
        </div>

        <div>
          <%= form.label :description, "Descripción", class: "block text-sm font-medium text-gray-700" %>
          <div class="mt-1">
            <%= form.text_area :description, rows: 6, class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md", placeholder: "Describe detalladamente tu problema o consulta..." %>
          </div>
        </div>

        <div>
          <%= form.label :priority, "Prioridad", class: "block text-sm font-medium text-gray-700" %>
          <div class="mt-1">
            <%= form.select :priority, 
                [["Baja", "low"], ["Normal", "normal"], ["Alta", "high"], ["Urgente", "urgent"]],
                { selected: @support_ticket.priority },
                { class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md" } %>
          </div>
          <% if current_user.business? %>
            <p class="mt-1 text-xs text-green-600">
              <strong>Nota:</strong> Como usuario Business, tu ticket se marcará automáticamente como prioridad alta.
            </p>
          <% end %>
        </div>

        <div class="flex justify-end">
          <%= link_to "Cancelar", support_tickets_path, class: "bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50" %>
          <%= form.submit "Crear Ticket", class: "ml-3 inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
