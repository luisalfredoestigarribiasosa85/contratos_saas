<div class="max-w-md mx-auto mt-12 p-8 bg-white rounded-xl shadow-md">
  <h2 class="text-2xl font-semibold mb-6 text-center text-gray-700">Cambiar contraseña</h2>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-6" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>
    <%= f.hidden_field :reset_password_token %>

    <div>
      <%= f.label :password, "Nueva contraseña", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <% if @minimum_password_length %>
        <em class="text-xs text-gray-500 mb-1 block">Mínimo <%= @minimum_password_length %> caracteres</em>
      <% end %>
      <%= f.password_field :password, autofocus: true, autocomplete: "new-password",
        class: "w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent bg-gray-50" %>
    </div>

    <div>
      <%= f.label :password_confirmation, "Confirmar nueva contraseña", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password",
        class: "w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent bg-gray-50" %>
    </div>

    <div>
      <%= f.submit "Guardar nueva contraseña",
        class: "w-full py-3 px-6 bg-gradient-to-r from-blue-500 to-blue-700 hover:from-blue-600 hover:to-blue-800 text-white font-bold rounded-xl shadow-lg transform hover:-translate-y-0.5 hover:scale-105 transition-all duration-200 border border-blue-500 focus:outline-none focus:ring-4 focus:ring-blue-400/50" %>
    </div>
  <% end %>

  <div class="mt-4 text-center">
    <%= render "devise/shared/links" %>
  </div>
</div>
