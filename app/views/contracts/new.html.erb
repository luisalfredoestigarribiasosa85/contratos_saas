<div class="mb-6">
  <%= link_to "← Volver a plantillas", contract_templates_path, class: "text-sm text-indigo-600 hover:text-indigo-800" %>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Completar contrato</h1>
    <p class="mt-1 text-sm text-gray-500">Plantilla: <strong><%= @template.name %></strong></p>

    <%= form_with url: contracts_path, method: :post, class: "mt-6 space-y-4", data: { controller: "preview", preview_body_value: @template.body } do |f| %>
      <%= f.hidden_field :contract_template_id, value: @template.id %>

      <%
        placeholder_labels = {
          "anio" => "Año",
          "dia" => "Día",
          "dia_pago" => "Día de pago",
          "mes" => "Mes",
          "ciudad" => "Ciudad",
          "nombre_locador" => "Nombre del locador",
          "ci_locador" => "Cédula de identidad del locador",
          "domicilio_locador" => "Domicilio del locador",
          "nombre_locatario" => "Nombre del locatario",
          "ci_locatario" => "Cédula de identidad del locatario",
          "domicilio_locatario" => "Domicilio del locatario",
          "direccion_inmueble" => "Dirección del inmueble",
          "destino_inmueble" => "Destino del inmueble",
          "plazo_meses" => "Plazo (meses)",
          "fecha_inicio" => "Fecha de inicio",
          "fecha_fin" => "Fecha de fin",
          "monto_alquiler" => "Monto del alquiler",
          "monto_garantia" => "Monto de garantía",
          "servicios_a_cargo" => "Servicios a cargo del locatario",
          "dias_preaviso" => "Días de preaviso",
        }

        placeholder_hints = {
          "dia_pago" => "Ingrese solo un número del 1 al 31 (ej: 5)",
          "dia" => "Ingrese solo el número del día (ej: 15)",
          "mes" => "Ingrese el nombre del mes (ej: Marzo)",
          "anio" => "Ingrese el año con 4 dígitos (ej: 2026)",
          "plazo_meses" => "Cantidad de meses (ej: 12)",
          "fecha_inicio" => "Formato: dd/mm/aaaa (ej: 01/03/2026)",
          "fecha_fin" => "Formato: dd/mm/aaaa (ej: 01/03/2027)",
          "monto_alquiler" => "Solo números, sin puntos ni comas (ej: 2500000)",
          "monto_garantia" => "Solo números, sin puntos ni comas (ej: 5000000)",
          "ci_locador" => "Sin puntos (ej: 1234567)",
          "ci_locatario" => "Sin puntos (ej: 1234567)",
          "destino_inmueble" => "Ej: vivienda, comercio, oficina",
          "dias_preaviso" => "Cantidad de días (ej: 30)",
          "servicios_a_cargo" => "Ej: agua, luz y teléfono",
        }
      %>

      <% @template.placeholders.each do |placeholder| %>
        <div>
          <% label_text = placeholder_labels[placeholder] || placeholder.humanize %>
          <%= label_tag "contract_data[#{placeholder}]", label_text, class: "block text-sm font-medium text-gray-700" %>
          <%= text_field_tag "contract_data[#{placeholder}]", nil, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm px-3 py-2 border", required: true, placeholder: placeholder_hints[placeholder], data: { preview_target: "field", action: "input->preview#update" } %>
          <% if placeholder_hints[placeholder] %>
            <p class="mt-1 text-xs text-gray-400"><%= placeholder_hints[placeholder] %></p>
          <% end %>
        </div>
      <% end %>

      <div class="pt-4">
        <%= f.submit "Generar contrato", class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-md hover:bg-indigo-700 cursor-pointer" %>
      </div>
    <% end %>
  </div>

  <div>
    <h2 class="text-lg font-semibold text-gray-800">Vista previa</h2>
    <div class="mt-4 bg-white rounded-lg border border-gray-200 p-6 text-sm text-gray-700 whitespace-pre-wrap" data-preview-target="output">
      <%= @template.body %>
    </div>
  </div>
</div>
