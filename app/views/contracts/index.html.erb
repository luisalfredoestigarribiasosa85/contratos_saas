<div class="mb-8 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Mis Contratos</h1>
    <p class="mt-1 text-sm text-gray-500">Todos tus contratos generados.</p>
  </div>
  <%= link_to "Crear nuevo contrato", contract_templates_path, class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-md hover:bg-indigo-700 whitespace-nowrap" %>
</div>

<% if @contracts.any? %>
  <!-- Desktop Table -->
  <div class="hidden md:block bg-white shadow-sm rounded-lg border border-gray-200 overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Título</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Plantilla</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Fecha</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Acciones</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @contracts.each do |contract| %>
          <tr>
            <td class="px-6 py-4 whitespace-nowrap">
              <%= link_to contract.title, contract_path(contract), class: "text-sm font-medium text-indigo-600 hover:text-indigo-800" %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= contract.contract_template.name %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= l(contract.created_at, format: :short) %></td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm space-x-2">
              <%= link_to "Ver", contract_path(contract), class: "text-indigo-600 hover:text-indigo-800" %>
              <%= link_to "PDF", contract_path(contract, format: :pdf), class: "text-indigo-600 hover:text-indigo-800", target: "_blank" %>
              <%= button_to "Eliminar", contract_path(contract), method: :delete, class: "text-red-600 hover:text-red-800", data: { turbo_confirm: "¿Estás seguro?" } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  
  <!-- Mobile Cards -->
  <div class="md:hidden space-y-4">
    <% @contracts.each do |contract| %>
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4">
        <div class="flex justify-between items-start mb-2">
          <%= link_to contract.title, contract_path(contract), class: "text-sm font-medium text-indigo-600 hover:text-indigo-800" %>
          <span class="text-xs text-gray-500"><%= l(contract.created_at, format: :short) %></span>
        </div>
        <p class="text-sm text-gray-500 mb-3"><%= contract.contract_template.name %></p>
        <div class="flex space-x-3">
          <%= link_to "Ver", contract_path(contract), class: "text-sm text-indigo-600 hover:text-indigo-800" %>
          <%= link_to "PDF", contract_path(contract, format: :pdf), class: "text-sm text-indigo-600 hover:text-indigo-800", target: "_blank" %>
          <%= button_to "Eliminar", contract_path(contract), method: :delete, class: "text-sm text-red-600 hover:text-red-800", data: { turbo_confirm: "¿Estás seguro?" } %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="text-center py-12 bg-white rounded-lg border border-gray-200">
    <h3 class="text-lg font-medium text-gray-900">No tienes contratos aún</h3>
    <p class="mt-2 text-sm text-gray-500">Comienza creando tu primer contrato desde una plantilla.</p>
    <div class="mt-6">
      <%= link_to "Ver plantillas disponibles", contract_templates_path, class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-md hover:bg-indigo-700" %>
    </div>
  </div>
<% end %>
