<h1 class="text-2xl font-bold text-gray-900">Mi plan</h1>
<p class="mt-1 text-sm text-gray-500">Administrá tu suscripción</p>

<div class="mt-8 bg-white rounded-lg border border-gray-200 p-6">
  <div class="flex items-center justify-between">
    <div>
      <h2 class="text-lg font-semibold text-gray-900">
        Plan actual: <span class="text-indigo-600"><%= @subscription.plan_label %></span>
      </h2>
      <p class="mt-1 text-sm text-gray-500">
        <% if @subscription.lifetime? %>
          Acceso de por vida
        <% elsif @subscription.free? %>
          <%= current_user.contracts_remaining %> contratos restantes este mes
        <% elsif @subscription.expires_at %>
          Válido hasta: <%= l(@subscription.expires_at.to_date, format: :long) %>
        <% else %>
          Activo
        <% end %>
      </p>
    </div>
    <% if @subscription.active? %>
      <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">Activo</span>
    <% else %>
      <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-red-100 text-red-800">Expirado</span>
    <% end %>
  </div>
</div>

<div class="mt-8">
  <h2 class="text-lg font-semibold text-gray-900">Opciones de plan</h2>
  <div class="mt-4 grid grid-cols-1 md:grid-cols-3 gap-6">

    <%# Plan Gratis %>
    <div class="bg-white rounded-lg border-2 <%= current_user.free? ? 'border-indigo-600' : 'border-gray-200' %> p-6">
      <h3 class="text-lg font-bold text-gray-900">Gratis</h3>
      <p class="mt-1 text-2xl font-extrabold text-gray-900">0 <span class="text-sm font-normal text-gray-500">Gs/mes</span></p>
      <ul class="mt-4 space-y-2">
        <li class="flex items-center text-sm text-gray-600"><span class="text-green-500 mr-2">&#10003;</span> 3 contratos al mes</li>
        <li class="flex items-center text-sm text-gray-600"><span class="text-green-500 mr-2">&#10003;</span> Plantillas básicas</li>
      </ul>
      <div class="mt-6">
        <% if current_user.free? %>
          <button class="block w-full text-center px-4 py-2 rounded-lg bg-gray-100 text-gray-500 font-semibold cursor-not-allowed" disabled>Plan Actual</button>
        <% else %>
          <%= button_to "Cambiar a Gratis", downgrade_account_plan_path(plan: "free"), data: { turbo_confirm: "¿Estás seguro? Perderás las funcionalidades de tu plan actual." }, method: :post, class: "block w-full text-center px-4 py-2 rounded-lg bg-white border border-gray-300 text-gray-700 font-semibold hover:bg-gray-50 cursor-pointer" %>
        <% end %>
      </div>
    </div>

    <%# Plan Pro %>
    <div class="bg-white rounded-lg border-2 <%= current_user.pro? && !@subscription&.lifetime? ? 'border-indigo-600' : 'border-gray-200' %> p-6 relative">
      <h3 class="text-lg font-bold text-gray-900">Pro</h3>
      <p class="mt-1 text-2xl font-extrabold text-gray-900">39.000 <span class="text-sm font-normal text-gray-500">Gs/mes</span></p>
      <ul class="mt-4 space-y-2">
        <% ["Contratos ilimitados", "Todas las plantillas", "PDF sin marca de agua", "Historial"].each do |f| %>
          <li class="flex items-center text-sm text-gray-600"><span class="text-green-500 mr-2">&#10003;</span> <%= f %></li>
        <% end %>
      </ul>
      <div class="mt-6 space-y-3">
        <% if current_user.pro? && !@subscription&.lifetime? %>
          <button class="block w-full text-center px-4 py-2 rounded-lg bg-gray-100 text-gray-500 font-semibold cursor-not-allowed" disabled>Plan Actual</button>
        <% else %>
          <% if current_user.business? %>
            <%= button_to "Cambiar a Pro", downgrade_account_plan_path(plan: "pro"), data: { turbo_confirm: "¿Estás seguro de hacer el cambio a Pro?" }, method: :post, class: "block w-full text-center px-4 py-2 rounded-lg bg-white border border-gray-300 text-gray-700 font-semibold hover:bg-gray-50 cursor-pointer" %>
          <% else %>
            <%= link_to "Mejorar a Pro", checkout_account_plan_path(plan: "pro"), class: "block w-full text-center px-4 py-2 rounded-lg bg-indigo-600 text-white font-semibold hover:bg-indigo-700" %>
          <% end %>
        <% end %>
        
        <% if @subscription&.lifetime? %>
          <button class="block w-full text-center px-4 py-2 rounded-lg bg-amber-100 text-amber-700 font-semibold cursor-not-allowed" disabled>Lifetime Activo</button>
        <% else %>
          <%= link_to "Lifetime (250.000 Gs)", checkout_account_plan_path(plan: "pro", lifetime: true), class: "block w-full text-center px-4 py-2 rounded-lg bg-amber-50 border border-amber-200 text-amber-700 text-sm font-semibold hover:bg-amber-100" %>
        <% end %>
      </div>
    </div>

    <%# Plan Business %>
    <div class="bg-white rounded-lg border-2 <%= current_user.business? ? 'border-indigo-600' : 'border-gray-200' %> p-6">
      <h3 class="text-lg font-bold text-gray-900">Business</h3>
      <p class="mt-1 text-2xl font-extrabold text-gray-900">120.000 <span class="text-sm font-normal text-gray-500">Gs/mes</span></p>
      <ul class="mt-4 space-y-2">
        <% ["Soporte prioritario", "Plantillas personalizadas", "Exportación masiva"].each do |f| %>
          <li class="flex items-center text-sm text-gray-600"><span class="text-green-500 mr-2">&#10003;</span> <%= f %></li>
        <% end %>
      </ul>
      <div class="mt-6">
        <% if current_user.business? %>
          <button class="block w-full text-center px-4 py-2 rounded-lg bg-gray-100 text-gray-500 font-semibold cursor-not-allowed" disabled>Plan Actual</button>
        <% else %>
          <%= link_to "Mejorar a Business", checkout_account_plan_path(plan: "business"), class: "block w-full text-center px-4 py-2 rounded-lg bg-gray-900 text-white font-semibold hover:bg-gray-800" %>
        <% end %>
      </div>
    </div>

  </div>
</div>
