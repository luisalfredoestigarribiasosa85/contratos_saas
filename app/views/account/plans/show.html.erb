<h1 class="text-2xl font-bold text-gray-900">Mi plan</h1>
<p class="mt-1 text-sm text-gray-500">Administrá tu suscripción</p>

<div class="mt-8 bg-white rounded-lg border border-gray-200 p-6">
  <div class="flex items-center justify-between">
    <div>
      <h2 class="text-lg font-semibold text-gray-900">
        Plan actual: <span class="text-indigo-600"><%= @subscription.plan_label %></span>
      </h2>
      <p class="mt-1 text-sm text-gray-500">
        <% if @subscription.lifetime? %>
          Acceso de por vida
        <% elsif @subscription.free? %>
          <%= current_user.contracts_remaining %> contratos restantes este mes
        <% elsif @subscription.expires_at %>
          Válido hasta: <%= l(@subscription.expires_at.to_date, format: :long) %>
        <% else %>
          Activo
        <% end %>
      </p>
    </div>
    <% if @subscription.active? %>
      <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">Activo</span>
    <% else %>
      <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-red-100 text-red-800">Expirado</span>
    <% end %>
  </div>
</div>

<% if current_user.free? %>
  <div class="mt-8">
    <h2 class="text-lg font-semibold text-gray-900">Mejorá tu plan</h2>
    <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-6">

      <div class="bg-white rounded-lg border-2 border-indigo-600 p-6">
        <h3 class="text-lg font-bold text-gray-900">Pro</h3>
        <p class="mt-1 text-2xl font-extrabold text-gray-900">39.000 <span class="text-sm font-normal text-gray-500">Gs/mes</span></p>
        <ul class="mt-4 space-y-2">
          <% ["Contratos ilimitados", "Todas las plantillas", "PDF sin marca de agua", "Historial completo"].each do |f| %>
            <li class="flex items-center text-sm text-gray-600">
              <span class="text-green-500 mr-2">&#10003;</span> <%= f %>
            </li>
          <% end %>
        </ul>
        <div class="mt-6">
          <%= link_to "Elegir Pro", checkout_account_plan_path(plan: "pro"), class: "block w-full text-center px-4 py-2 rounded-lg bg-indigo-600 text-white font-semibold hover:bg-indigo-700" %>
        </div>
      </div>

      <div class="bg-gradient-to-br from-amber-50 to-orange-50 rounded-lg border border-amber-200 p-6">
        <span class="inline-block bg-amber-100 text-amber-800 text-xs font-bold px-2 py-0.5 rounded-full uppercase">Oferta</span>
        <h3 class="mt-2 text-lg font-bold text-gray-900">Acceso de por vida</h3>
        <p class="mt-1 text-2xl font-extrabold text-gray-900">250.000 <span class="text-sm font-normal text-gray-500">Gs — pago único</span></p>
        <p class="mt-2 text-sm text-gray-600">Todas las funciones Pro para siempre.</p>
        <div class="mt-6">
          <%= link_to "Obtener acceso de por vida", checkout_account_plan_path(plan: "pro", lifetime: true), class: "block w-full text-center px-4 py-2 rounded-lg bg-amber-600 text-white font-semibold hover:bg-amber-700" %>
        </div>
      </div>

    </div>
  </div>
<% end %>
