<!DOCTYPE html>
<html class="h-full bg-gray-50">
  <head>
    <title><%= content_for(:title) || "ContratoFácil" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= content_for(:meta_description) || "Crea contratos de alquiler, pagarés y documentos legales en segundos." %>">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="ContratoFácil">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full">
    <% if user_signed_in? %>
      <nav class="bg-white shadow-sm border-b border-gray-200" data-controller="toggle">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex justify-between h-16">
            <!-- Logo and Desktop Nav -->
            <div class="flex items-center">
              <%= link_to "ContratoFácil", authenticated_root_path, class: "text-xl font-bold text-indigo-600" %>
              <!-- Desktop Navigation -->
              <div class="hidden md:flex ml-8 space-x-6">
                <%= link_to "Dashboard", dashboard_path, class: "text-gray-600 hover:text-gray-900 text-sm font-medium" %>
                <%= link_to "Plantillas", contract_templates_path, class: "text-gray-600 hover:text-gray-900 text-sm font-medium" %>
                <%= link_to "Mis Contratos", contracts_path, class: "text-gray-600 hover:text-gray-900 text-sm font-medium" %>
                <%= link_to "Mi Plan", account_plan_path, class: "text-gray-600 hover:text-gray-900 text-sm font-medium" %>
              </div>
            </div>
            
            <!-- Desktop User Menu -->
            <div class="hidden md:flex items-center space-x-4">
              <% if current_user.admin? %>
                <%= link_to "Admin", admin_support_tickets_path, class: "text-xs font-semibold px-3 py-1 rounded-full bg-purple-100 text-purple-700 hover:bg-purple-200" %>
              <% end %>
              <% if current_user.free? %>
                <%= link_to "Upgrade", account_plan_path, class: "text-xs font-semibold px-3 py-1 rounded-full bg-indigo-100 text-indigo-700 hover:bg-indigo-200" %>
              <% else %>
                <span class="text-xs font-semibold px-3 py-1 rounded-full bg-green-100 text-green-700"><%= current_user.subscription&.plan_label %></span>
              <% end %>
              <span class="text-sm text-gray-500 truncate max-w-[150px]"><%= current_user.email %></span>
              <%= button_to "Cerrar sesión", destroy_user_session_path, method: :delete, class: "text-sm text-red-600 hover:text-red-800 font-medium" %>
            </div>
            
            <!-- Mobile Menu Button -->
            <div class="flex items-center md:hidden">
              <button type="button" data-action="click->toggle#toggle" class="inline-flex items-center justify-center p-2 rounded-md text-gray-400 hover:text-gray-500 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-indigo-500" aria-expanded="false">
                <span class="sr-only">Abrir menú</span>
                <svg class="block h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
              </button>
            </div>
          </div>
        </div>
        
        <!-- Mobile Menu -->
        <div class="hidden md:hidden" data-toggle-target="content">
          <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3 border-t border-gray-200">
            <%= link_to "Dashboard", dashboard_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-gray-900 hover:bg-gray-50" %>
            <%= link_to "Plantillas", contract_templates_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-gray-900 hover:bg-gray-50" %>
            <%= link_to "Mis Contratos", contracts_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-gray-900 hover:bg-gray-50" %>
            <%= link_to "Mi Plan", account_plan_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-gray-900 hover:bg-gray-50" %>
          </div>
          <div class="pt-4 pb-4 border-t border-gray-200">
            <div class="px-4 space-y-3">
              <div class="text-base font-medium text-gray-800 truncate"><%= current_user.email %></div>
              <% if current_user.admin? %>
                <%= link_to "Panel Admin", admin_support_tickets_path, class: "block text-sm font-medium text-purple-600 hover:text-purple-800" %>
              <% end %>
              <% if current_user.free? %>
                <%= link_to "Upgrade a Pro", account_plan_path, class: "block text-sm font-medium text-indigo-600 hover:text-indigo-800" %>
              <% else %>
                <div class="text-sm font-medium text-green-600">Plan <%= current_user.subscription&.plan_label %></div>
              <% end %>
              <%= button_to "Cerrar sesión", destroy_user_session_path, method: :delete, class: "block text-sm font-medium text-red-600 hover:text-red-800" %>
            </div>
          </div>
        </div>
      </nav>
    <% end %>

    <% if notice.present? %>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
        <div class="rounded-md bg-green-50 p-4">
          <p class="text-sm text-green-800"><%= notice %></p>
        </div>
      </div>
    <% end %>

    <% if alert.present? %>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
        <div class="rounded-md bg-red-50 p-4">
          <p class="text-sm text-red-800"><%= alert %></p>
        </div>
      </div>
    <% end %>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <%= yield %>
    </main>
  </body>
</html>
