<!DOCTYPE html>
<html class="h-full">
  <head>
    <title><%= content_for(:title) || "ContratoFácil | Generador de contratos para Paraguay" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= content_for(:meta_description) || "Crea contratos de alquiler, pagarés y documentos legales en segundos. Plantillas listas para Paraguay." %>">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="ContratoFácil">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full bg-white">
    <nav class="bg-white border-b border-gray-100" data-controller="toggle">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
          <!-- Logo and Desktop Nav -->
          <div class="flex items-center">
            <%= link_to "ContratoFácil", root_path, class: "text-xl font-bold text-indigo-600" %>
            <!-- Desktop Navigation Links -->
            <div class="hidden md:flex ml-8 space-x-6 desktop-nav">
              <%= link_to "Inicio", root_path, class: "text-gray-600 hover:text-gray-900 text-sm font-medium" %>
              <%= link_to "Precios", pricing_path, class: "text-gray-600 hover:text-gray-900 text-sm font-medium" %>
            </div>
          </div>

          <!-- Desktop Auth Buttons -->
          <div class="hidden md:flex items-center space-x-4 desktop-nav">
            <% if user_signed_in? %>
              <%= link_to "Dashboard", authenticated_root_path, class: "text-sm text-indigo-600 hover:text-indigo-800 font-medium" %>
            <% else %>
              <%= link_to "Iniciar sesión", new_user_session_path, class: "text-sm text-gray-600 hover:text-gray-900 font-medium" %>
              <%= link_to "Registrarse", new_user_registration_path, class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-md hover:bg-indigo-700" %>
            <% end %>
          </div>

          <!-- Mobile Menu Button (only visible on small screens) -->
          <div class="md:!hidden mobile-menu-btn">
            <button type="button" data-action="click->toggle#toggle" class="inline-flex items-center justify-center p-2 rounded-md text-gray-400 hover:text-gray-500 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-indigo-500" aria-expanded="false">
              <span class="sr-only">Abrir menú</span>
              <svg class="block h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Mobile Menu -->
      <div class="hidden md:hidden mobile-menu-panel" data-toggle-target="content">
        <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3 border-t border-gray-200">
          <%= link_to "Inicio", root_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-gray-900 hover:bg-gray-50" %>
          <%= link_to "Precios", pricing_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-gray-900 hover:bg-gray-50" %>
        </div>
        <div class="pt-4 pb-4 border-t border-gray-200">
          <div class="px-4 space-y-3">
            <% if user_signed_in? %>
              <%= link_to "Dashboard", authenticated_root_path, class: "block text-sm font-medium text-indigo-600 hover:text-indigo-800" %>
            <% else %>
              <%= link_to "Iniciar sesión", new_user_session_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-gray-900 hover:bg-gray-50" %>
              <%= link_to "Registrarse", new_user_registration_path, class: "block w-full text-center px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-md hover:bg-indigo-700" %>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <% if notice.present? %>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
        <div class="rounded-md bg-green-50 p-4">
          <p class="text-sm text-green-800"><%= notice %></p>
        </div>
      </div>
    <% end %>

    <% if alert.present? %>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
        <div class="rounded-md bg-red-50 p-4">
          <p class="text-sm text-red-800"><%= alert %></p>
        </div>
      </div>
    <% end %>

    <%= yield %>

    <footer class="bg-gray-900 text-gray-400">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div>
            <h3 class="text-white font-bold text-lg">ContratoFácil</h3>
            <p class="mt-2 text-sm">Generador de contratos legales para Paraguay. Simple, rápido y profesional.</p>
          </div>
          <div>
            <h4 class="text-white font-semibold text-sm uppercase tracking-wide">Enlaces</h4>
            <ul class="mt-3 space-y-2">
              <li><%= link_to "Precios", pricing_path, class: "text-sm hover:text-white" %></li>
              <li><%= link_to "Iniciar sesión", new_user_session_path, class: "text-sm hover:text-white" %></li>
              <li><%= link_to "Registrarse", new_user_registration_path, class: "text-sm hover:text-white" %></li>
            </ul>
          </div>
          <div>
            <h4 class="text-white font-semibold text-sm uppercase tracking-wide">Contacto</h4>
            <ul class="mt-3 space-y-2">
              <li class="text-sm">Paraguay</li>
            </ul>
          </div>
        </div>
        <div class="mt-8 pt-8 border-t border-gray-800 text-center text-sm">
          <p>&copy; <%= Date.current.year %> ContratoFácil. Todos los derechos reservados.</p>
        </div>
      </div>
    </footer>
  </body>
</html>
