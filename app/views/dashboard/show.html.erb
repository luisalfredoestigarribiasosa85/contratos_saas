<div class="mb-8 flex justify-between items-center">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>
    <p class="mt-1 text-sm text-gray-500">Bienvenido a ContratoFácil. Gestiona tus contratos legales fácilmente.</p>
  </div>
  <%= link_to "Crear nuevo contrato", contract_templates_path, class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-md hover:bg-indigo-700" %>
</div>

<% if current_user.free? %>
  <div class="mb-6 bg-indigo-50 rounded-lg border border-indigo-200 p-4 flex items-center justify-between">
    <div>
      <p class="text-sm font-medium text-indigo-800">
        Plan Gratis -- <%= current_user.contracts_remaining %> de <%= current_user.monthly_contract_limit %> contratos restantes este mes
      </p>
      <div class="mt-1 w-48 bg-indigo-200 rounded-full h-2">
        <% used_pct = ((current_user.monthly_contract_limit - current_user.contracts_remaining).to_f / current_user.monthly_contract_limit * 100).round %>
        <div class="bg-indigo-600 h-2 rounded-full" style="width: <%= used_pct %>%"></div>
      </div>
    </div>
    <%= link_to "Mejorar plan", account_plan_path, class: "text-sm font-semibold text-indigo-700 hover:text-indigo-900" %>
  </div>
<% elsif current_user.business? %>
  <div class="mb-6 bg-green-50 rounded-lg border border-green-200 p-4">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm font-medium text-green-800">
          <strong>Plan Business</strong> -- Acceso completo a todas las funcionalidades
        </p>
        <p class="mt-1 text-xs text-green-600">Múltiples usuarios, plantillas personalizadas, logo en contratos y soporte prioritario</p>
      </div>
      <div class="flex space-x-2">
        <%= link_to "Gestionar Empresa", company_path(@company), class: "text-sm font-semibold text-green-700 hover:text-green-900" %>
      </div>
    </div>
  </div>
<% else %>
  <div class="mb-6 bg-blue-50 rounded-lg border border-blue-200 p-4">
    <p class="text-sm font-medium text-blue-800">
      <strong>Plan Pro</strong> -- Contratos ilimitados sin marca de agua
    </p>
  </div>
<% end %>

<!-- Business Features Section -->
<% if current_user.business? && @company %>
  <div class="mb-8">
    <h2 class="text-lg font-semibold text-gray-800 mb-4">Características Business</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      <div class="bg-white rounded-lg border border-gray-200 p-4 hover:shadow-md transition-shadow">
        <div class="flex items-center justify-between mb-3">
          <div class="h-10 w-10 bg-indigo-100 rounded-lg flex items-center justify-center">
            <svg class="h-6 w-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <span class="text-xs font-medium text-green-600">Activo</span>
        </div>
        <h3 class="font-medium text-gray-900">Equipo</h3>
        <p class="text-sm text-gray-500 mt-1"><%= @company_users.count %> miembros</p>
        <%= link_to "Gestionar", company_path(@company), class: "text-indigo-600 hover:text-indigo-800 text-sm mt-2 inline-block" %>
      </div>
      
      <div class="bg-white rounded-lg border border-gray-200 p-4 hover:shadow-md transition-shadow">
        <div class="flex items-center justify-between mb-3">
          <div class="h-10 w-10 bg-purple-100 rounded-lg flex items-center justify-center">
            <svg class="h-6 w-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <span class="text-xs font-medium text-green-600">Activo</span>
        </div>
        <h3 class="font-medium text-gray-900">Plantillas</h3>
        <p class="text-sm text-gray-500 mt-1"><%= @custom_templates.count %> personalizadas</p>
        <%= link_to "Gestionar", custom_templates_path, class: "text-indigo-600 hover:text-indigo-800 text-sm mt-2 inline-block" %>
      </div>
      
      <div class="bg-white rounded-lg border border-gray-200 p-4 hover:shadow-md transition-shadow">
        <div class="flex items-center justify-between mb-3">
          <div class="h-10 w-10 bg-green-100 rounded-lg flex items-center justify-center">
            <svg class="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <span class="text-xs font-medium text-green-600">Activo</span>
        </div>
        <h3 class="font-medium text-gray-900">Soporte</h3>
        <p class="text-sm text-gray-500 mt-1"><%= @support_tickets.count %> tickets</p>
        <%= link_to "Gestionar", support_tickets_path, class: "text-indigo-600 hover:text-indigo-800 text-sm mt-2 inline-block" %>
      </div>
      
      <div class="bg-white rounded-lg border border-gray-200 p-4 hover:shadow-md transition-shadow">
        <div class="flex items-center justify-between mb-3">
          <div class="h-10 w-10 bg-orange-100 rounded-lg flex items-center justify-center">
            <svg class="h-6 w-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <span class="text-xs font-medium <%= @company.logo.attached? ? 'text-green-600' : 'text-gray-400' %>">
            <%= @company.logo.attached? ? 'Activo' : 'Pendiente' %>
          </span>
        </div>
        <h3 class="font-medium text-gray-900">Logo</h3>
        <p class="text-sm text-gray-500 mt-1"><%= @company.logo.attached? ? 'Configurado' : 'Sin configurar' %></p>
        <%= link_to "Configurar", edit_company_path(@company), class: "text-indigo-600 hover:text-indigo-800 text-sm mt-2 inline-block" %>
      </div>
    </div>
  </div>
<% end %>

<% if @contracts.any? %>
  <h2 class="text-lg font-semibold text-gray-800 mb-4">Contratos recientes</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% @contracts.limit(6).each do |contract| %>
      <%= link_to contract_path(contract), class: "block bg-white rounded-lg shadow-sm border border-gray-200 p-6 hover:shadow-md transition-shadow" do %>
        <h3 class="text-sm font-semibold text-gray-900 truncate"><%= contract.title %></h3>
        <p class="mt-1 text-xs text-gray-500"><%= contract.contract_template.category %></p>
        <p class="mt-2 text-xs text-gray-400">Creado: <%= l(contract.created_at, format: :short) %></p>
      <% end %>
    <% end %>
  </div>

  <% if @contracts.size > 6 %>
    <div class="mt-6 text-center">
      <%= link_to "Ver todos los contratos", contracts_path, class: "text-indigo-600 hover:text-indigo-800 text-sm font-medium" %>
    </div>
  <% end %>
<% else %>
  <div class="text-center py-12 bg-white rounded-lg border border-gray-200">
    <h3 class="text-lg font-medium text-gray-900">No tienes contratos aún</h3>
    <p class="mt-2 text-sm text-gray-500">Comienza creando tu primer contrato desde una plantilla.</p>
    <div class="mt-6">
      <%= link_to "Ver plantillas disponibles", contract_templates_path, class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-md hover:bg-indigo-700" %>
    </div>
  </div>
<% end %>
