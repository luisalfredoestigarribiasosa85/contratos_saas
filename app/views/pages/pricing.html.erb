<% content_for(:title) { "Precios | ContratoFácil" } %>
<% content_for(:meta_description) { "Planes accesibles para generar contratos legales en Paraguay. Plan gratuito disponible." } %>

<section class="py-16 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <h1 class="text-4xl font-extrabold text-gray-900">Planes y precios</h1>
      <p class="mt-4 text-lg text-gray-500">Elegí el plan que mejor se adapte a tus necesidades</p>
    </div>

    <%# ── Plan Cards ── %>
    <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">

      <%# Free Plan %>
      <div class="bg-white rounded-2xl border border-gray-200 p-8 flex flex-col">
        <h3 class="text-lg font-semibold text-gray-900">Gratis</h3>
        <div class="mt-4">
          <span class="text-4xl font-extrabold text-gray-900">Gs. 0</span>
        </div>
        <p class="mt-2 text-sm text-gray-500">Para empezar sin compromiso</p>

        <ul class="mt-8 space-y-3 flex-1">
          <% [
            "3 contratos por mes",
            "Plantillas básicas",
            "Exportar a PDF",
            "PDF con marca de agua",
          ].each do |feature| %>
            <li class="flex items-start">
              <span class="text-green-500 mr-2 mt-0.5">&#10003;</span>
              <span class="text-sm text-gray-600"><%= feature %></span>
            </li>
          <% end %>
        </ul>

        <div class="mt-8">
          <%= link_to "Crear cuenta gratis", new_user_registration_path, class: "block w-full text-center px-6 py-3 rounded-lg border-2 border-indigo-600 text-indigo-600 font-semibold hover:bg-indigo-50 transition" %>
        </div>
      </div>

      <%# Pro Plan %>
      <div class="bg-white rounded-2xl border-2 border-indigo-600 p-8 flex flex-col relative shadow-lg">
        <div class="absolute -top-4 left-1/2 -translate-x-1/2">
          <span class="bg-indigo-600 text-white text-xs font-bold px-4 py-1 rounded-full uppercase tracking-wide">Popular</span>
        </div>

        <h3 class="text-lg font-semibold text-gray-900">Pro</h3>
        <div class="mt-4">
          <span class="text-4xl font-extrabold text-gray-900">39.000</span>
          <span class="text-lg text-gray-500"> Gs/mes</span>
        </div>
        <p class="mt-2 text-sm text-gray-500">Para profesionales y emprendedores</p>

        <ul class="mt-8 space-y-3 flex-1">
          <% [
            "Contratos ilimitados",
            "Todas las plantillas",
            "PDF sin marca de agua",
            "Historial completo",
            "Guardar datos de clientes",
          ].each do |feature| %>
            <li class="flex items-start">
              <span class="text-green-500 mr-2 mt-0.5">&#10003;</span>
              <span class="text-sm text-gray-600"><%= feature %></span>
            </li>
          <% end %>
        </ul>

        <div class="mt-8">
          <% if user_signed_in? %>
            <%= link_to "Elegir plan Pro", checkout_account_plan_path(plan: "pro"), class: "block w-full text-center px-6 py-3 rounded-lg bg-indigo-600 text-white font-semibold hover:bg-indigo-700 transition shadow" %>
          <% else %>
            <%= link_to "Elegir plan Pro", new_user_registration_path, class: "block w-full text-center px-6 py-3 rounded-lg bg-indigo-600 text-white font-semibold hover:bg-indigo-700 transition shadow" %>
          <% end %>
        </div>
      </div>

      <%# Business Plan %>
      <div class="bg-white rounded-2xl border border-gray-200 p-8 flex flex-col">
        <h3 class="text-lg font-semibold text-gray-900">Business</h3>
        <div class="mt-4">
          <span class="text-4xl font-extrabold text-gray-900">120.000</span>
          <span class="text-lg text-gray-500"> Gs/mes</span>
        </div>
        <p class="mt-2 text-sm text-gray-500">Para empresas y equipos</p>

        <ul class="mt-8 space-y-3 flex-1">
          <% [
            "Todo lo del plan Pro",
            "Múltiples usuarios",
            "Plantillas personalizadas",
            "Logo propio en contratos",
            "Soporte prioritario",
          ].each do |feature| %>
            <li class="flex items-start">
              <span class="text-green-500 mr-2 mt-0.5">&#10003;</span>
              <span class="text-sm text-gray-600"><%= feature %></span>
            </li>
          <% end %>
        </ul>

        <div class="mt-8">
          <% if user_signed_in? %>
            <%= link_to "Contactar", checkout_account_plan_path(plan: "business"), class: "block w-full text-center px-6 py-3 rounded-lg border-2 border-gray-300 text-gray-700 font-semibold hover:bg-gray-50 transition" %>
          <% else %>
            <%= link_to "Contactar", new_user_registration_path, class: "block w-full text-center px-6 py-3 rounded-lg border-2 border-gray-300 text-gray-700 font-semibold hover:bg-gray-50 transition" %>
          <% end %>
        </div>
      </div>
    </div>

    <%# ── Lifetime Plan ── %>
    <div class="mt-16 max-w-2xl mx-auto">
      <div class="bg-gradient-to-r from-amber-50 to-orange-50 rounded-2xl border border-amber-200 p-8 text-center">
        <span class="inline-block bg-amber-100 text-amber-800 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">Oferta especial</span>
        <h3 class="mt-4 text-2xl font-bold text-gray-900">Acceso de por vida</h3>
        <div class="mt-3">
          <span class="text-4xl font-extrabold text-gray-900">250.000</span>
          <span class="text-lg text-gray-500"> Gs — pago único</span>
        </div>
        <p class="mt-3 text-gray-600">Todas las funciones del plan Pro para siempre. Sin pagos mensuales.</p>
        <div class="mt-6">
          <% if user_signed_in? %>
            <%= link_to "Obtener acceso de por vida", checkout_account_plan_path(plan: "pro", lifetime: true), class: "inline-flex items-center px-8 py-3 rounded-lg bg-amber-600 text-white font-semibold hover:bg-amber-700 transition shadow" %>
          <% else %>
            <%= link_to "Obtener acceso de por vida", new_user_registration_path, class: "inline-flex items-center px-8 py-3 rounded-lg bg-amber-600 text-white font-semibold hover:bg-amber-700 transition shadow" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>
