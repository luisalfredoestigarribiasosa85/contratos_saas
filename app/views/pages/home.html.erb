<% content_for(:title) { "ContratoFácil | Generador de contratos para Paraguay" } %>
<% content_for(:meta_description) { "Crea contratos de alquiler, pagarés y documentos legales en segundos. Plantillas listas para Paraguay. Sin abogados. Sin complicaciones." } %>

<%# ── Hero Section ── %>
<section class="bg-gradient-to-br from-indigo-600 to-indigo-800 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
    <div class="text-center max-w-3xl mx-auto">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight">
        Generá contratos legales en segundos
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-indigo-100">
        Plantillas listas para Paraguay. Sin abogados. Sin complicaciones.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <%= link_to "Probar Gratis", new_user_registration_path, class: "inline-flex items-center justify-center px-8 py-3 text-base font-semibold rounded-lg bg-white text-indigo-700 hover:bg-indigo-50 shadow-lg" %>
        <%= link_to "Ver Precios", pricing_path, class: "inline-flex items-center justify-center px-8 py-3 text-base font-semibold rounded-lg border-2 border-white text-white hover:bg-white/10" %>
      </div>
    </div>
  </div>
</section>

<%# ── How It Works ── %>
<section class="py-16 lg:py-24 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <h2 class="text-3xl font-bold text-gray-900">Cómo funciona</h2>
      <p class="mt-3 text-lg text-gray-500">Tres pasos simples para tu contrato listo</p>
    </div>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="text-center">
        <div class="mx-auto w-16 h-16 flex items-center justify-center rounded-full bg-indigo-100 text-indigo-600 text-2xl font-bold">1</div>
        <h3 class="mt-4 text-lg font-semibold text-gray-900">Elegí una plantilla</h3>
        <p class="mt-2 text-gray-500">Seleccioná entre nuestras plantillas de contratos adaptadas a la legislación paraguaya.</p>
      </div>

      <div class="text-center">
        <div class="mx-auto w-16 h-16 flex items-center justify-center rounded-full bg-indigo-100 text-indigo-600 text-2xl font-bold">2</div>
        <h3 class="mt-4 text-lg font-semibold text-gray-900">Completá los datos</h3>
        <p class="mt-2 text-gray-500">Llená los campos con la información de las partes. Vista previa en tiempo real.</p>
      </div>

      <div class="text-center">
        <div class="mx-auto w-16 h-16 flex items-center justify-center rounded-full bg-indigo-100 text-indigo-600 text-2xl font-bold">3</div>
        <h3 class="mt-4 text-lg font-semibold text-gray-900">Descargá el contrato en PDF</h3>
        <p class="mt-2 text-gray-500">Descargá tu contrato profesional listo para firmar en formato PDF.</p>
      </div>
    </div>
  </div>
</section>

<%# ── Use Cases ── %>
<section class="py-16 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <h2 class="text-3xl font-bold text-gray-900">Plantillas disponibles</h2>
      <p class="mt-3 text-lg text-gray-500">Contratos para las necesidades más comunes en Paraguay</p>
    </div>

    <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <% [
        { title: "Alquiler de inmuebles", desc: "Contratos de alquiler con todas las cláusulas necesarias para proteger a ambas partes.", icon: "🏠" },
        { title: "Compraventa", desc: "Contratos de compraventa de inmuebles y vehículos adaptados a la ley paraguaya.", icon: "🤝" },
        { title: "Pagarés", desc: "Documentos de pagaré con validez legal conforme al Código Civil.", icon: "📄" },
        { title: "Recibos de dinero", desc: "Recibos estándar como constancia de pago para cualquier transacción.", icon: "💰" },
        { title: "Contratos de servicios", desc: "Contratos de prestación de servicios profesionales claros y completos.", icon: "⚙️" },
        { title: "Contratos de trabajo", desc: "Contratos laborales para formalizar relaciones de trabajo.", icon: "👷" },
      ].each do |use_case| %>
        <div class="bg-white rounded-lg border border-gray-200 p-6 hover:shadow-md transition-shadow">
          <span class="text-3xl"><%= use_case[:icon] %></span>
          <h3 class="mt-3 text-lg font-semibold text-gray-900"><%= use_case[:title] %></h3>
          <p class="mt-2 text-sm text-gray-500"><%= use_case[:desc] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ── Benefits ── %>
<section class="py-16 lg:py-24 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <h2 class="text-3xl font-bold text-gray-900">Por qué elegir ContratoFácil</h2>
    </div>

    <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      <% [
        { title: "Ahorrá tiempo", desc: "Generá contratos en menos de 5 minutos. Sin trámites complicados.", icon: "⚡" },
        { title: "Documentos profesionales", desc: "Contratos con formato profesional listos para firmar e imprimir.", icon: "📋" },
        { title: "Historial de contratos", desc: "Todos tus contratos guardados y accesibles cuando los necesites.", icon: "📁" },
        { title: "Desde cualquier dispositivo", desc: "Accedé desde tu celular, tablet o computadora en cualquier momento.", icon: "📱" },
      ].each do |benefit| %>
        <div class="text-center">
          <span class="text-4xl"><%= benefit[:icon] %></span>
          <h3 class="mt-3 text-lg font-semibold text-gray-900"><%= benefit[:title] %></h3>
          <p class="mt-2 text-sm text-gray-500"><%= benefit[:desc] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ── Social Proof ── %>
<section class="py-16 lg:py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <p class="text-xl text-gray-500 italic">"Usado por emprendedores y profesionales en Paraguay"</p>
    <div class="mt-8">
      <%= link_to "Comenzar ahora — es gratis", new_user_registration_path, class: "inline-flex items-center justify-center px-8 py-3 text-base font-semibold rounded-lg bg-indigo-600 text-white hover:bg-indigo-700 shadow-lg" %>
    </div>
  </div>
</section>
