<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900">Panel de Soporte - Administración</h1>
    <p class="mt-1 text-sm text-gray-500">Gestiona los tickets de soporte de los usuarios</p>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
    <div class="bg-white rounded-lg shadow-sm p-6">
      <div class="text-sm font-medium text-gray-500">Total Tickets</div>
      <div class="mt-2 text-3xl font-bold text-gray-900"><%= SupportTicket.count %></div>
    </div>
    <div class="bg-white rounded-lg shadow-sm p-6">
      <div class="text-sm font-medium text-gray-500">Abiertos</div>
      <div class="mt-2 text-3xl font-bold text-green-600"><%= SupportTicket.where(status: 'open').count %></div>
    </div>
    <div class="bg-white rounded-lg shadow-sm p-6">
      <div class="text-sm font-medium text-gray-500">En Progreso</div>
      <div class="mt-2 text-3xl font-bold text-yellow-600"><%= SupportTicket.where(status: 'in_progress').count %></div>
    </div>
    <div class="bg-white rounded-lg shadow-sm p-6">
      <div class="text-sm font-medium text-gray-500">Prioridad Alta/Urgente</div>
      <div class="mt-2 text-3xl font-bold text-red-600"><%= SupportTicket.where(priority: ['high', 'urgent']).count %></div>
    </div>
  </div>

  <!-- Tickets List -->
  <div class="bg-white shadow-sm rounded-lg overflow-hidden">
    <div class="px-4 py-5 sm:p-6 border-b border-gray-200">
      <h3 class="text-lg font-medium text-gray-900">Tickets Recientes</h3>
    </div>
    
    <% if @support_tickets.any? %>
      <ul class="divide-y divide-gray-200">
        <% @support_tickets.each do |ticket| %>
          <% priority_class = case ticket.priority
                               when 'urgent' then 'bg-red-100 text-red-800'
                               when 'high' then 'bg-orange-100 text-orange-800'
                               when 'normal' then 'bg-blue-100 text-blue-800'
                               when 'low' then 'bg-gray-100 text-gray-800'
                               else 'bg-gray-100 text-gray-800'
                               end %>
          <% status_class = case ticket.status
                            when 'open' then 'bg-green-100 text-green-800'
                            when 'in_progress' then 'bg-yellow-100 text-yellow-800'
                            when 'resolved' then 'bg-blue-100 text-blue-800'
                            when 'closed' then 'bg-gray-100 text-gray-800'
                            else 'bg-gray-100 text-gray-800'
                            end %>
          <li class="p-6 hover:bg-gray-50 cursor-pointer" onclick="window.location.href='<%= admin_support_ticket_path(ticket) %>'">
            <div class="flex items-start justify-between">
              <div class="flex-1 min-w-0">
                <div class="flex items-center space-x-3 mb-2">
                  <h4 class="text-sm font-medium text-gray-900 truncate"><%= ticket.subject %></h4>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= priority_class %>">
                    <%= ticket.priority.upcase %>
                  </span>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= status_class %>">
                    <%= ticket.status.gsub('_', ' ').upcase %>
                  </span>
                </div>
                <div class="flex items-center space-x-4 text-sm text-gray-500">
                  <span><%= ticket.user.email %></span>
                  <span><%= ticket.created_at.strftime('%d/%m/%Y %H:%M') %></span>
                  <span><%= ticket.reply_count %> respuestas</span>
                </div>
                <p class="mt-2 text-sm text-gray-600 line-clamp-2"><%= ticket.description.truncate(100) %></p>
              </div>
              <div class="ml-4 flex-shrink-0">
                <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
      
    <% else %>
      <div class="text-center py-12">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900">No hay tickets</h3>
        <p class="mt-1 text-sm text-gray-500">No hay tickets de soporte para mostrar.</p>
      </div>
    <% end %>
  </div>
</div>
