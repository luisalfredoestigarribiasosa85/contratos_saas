<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-6">
    <%= link_to "← Volver al Panel", admin_support_tickets_path, class: "text-sm text-indigo-600 hover:text-indigo-900" %>
  </div>

  <div class="bg-white shadow-sm rounded-lg">
    <div class="px-4 py-5 sm:p-6 border-b border-gray-200">
      <div class="flex items-start justify-between">
        <div class="flex-1">
          <h1 class="text-2xl font-bold text-gray-900 mb-2"><%= @support_ticket.subject %></h1>
          <div class="flex items-center space-x-3 mb-3">
            <% priority_class = case @support_ticket.priority
                                 when 'urgent' then 'bg-red-100 text-red-800'
                                 when 'high' then 'bg-orange-100 text-orange-800'
                                 when 'normal' then 'bg-blue-100 text-blue-800'
                                 when 'low' then 'bg-gray-100 text-gray-800'
                                 else 'bg-gray-100 text-gray-800'
                                 end %>
            <% status_class = case @support_ticket.status
                              when 'open' then 'bg-green-100 text-green-800'
                              when 'in_progress' then 'bg-yellow-100 text-yellow-800'
                              when 'resolved' then 'bg-blue-100 text-blue-800'
                              when 'closed' then 'bg-gray-100 text-gray-800'
                              else 'bg-gray-100 text-gray-800'
                              end %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= priority_class %>">
              Prioridad: <%= @support_ticket.priority.upcase %>
            </span>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= status_class %>">
              Estado: <%= @support_ticket.status.gsub('_', ' ').upcase %>
            </span>
          </div>
          <div class="flex items-center space-x-4 text-sm text-gray-500">
            <span><%= @support_ticket.user.email %></span>
            <span><%= @support_ticket.created_at.strftime('%d/%m/%Y %H:%M') %></span>
            <% if @support_ticket.user.business? %>
              <span class="text-green-600 font-medium">★ Usuario Business</span>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Update Status Form -->
    <div class="px-4 py-4 sm:px-6 border-b border-gray-200 bg-gray-50">
      <%= form_with(model: @support_ticket, url: admin_support_ticket_path(@support_ticket), method: :patch, local: true, class: "flex items-center space-x-4") do |form| %>
        <div>
          <%= form.label :status, "Cambiar Estado:", class: "text-sm font-medium text-gray-700" %>
          <%= form.select :status, 
              [["Abierto", "open"], ["En Progreso", "in_progress"], ["Resuelto", "resolved"], ["Cerrado", "closed"]],
              { selected: @support_ticket.status },
              { class: "ml-2 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-40 sm:text-sm border-gray-300 rounded-md" } %>
        </div>
        <%= form.submit "Actualizar", class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700" %>
      <% end %>
    </div>

    <!-- Original Message -->
    <div class="px-4 py-5 sm:p-6 border-b border-gray-200">
      <h3 class="text-sm font-medium text-gray-900 mb-3">Mensaje Original</h3>
      <div class="bg-gray-50 rounded-lg p-4">
        <p class="text-gray-700 whitespace-pre-wrap"><%= @support_ticket.description %></p>
      </div>
    </div>

    <!-- Replies -->
    <div class="px-4 py-5 sm:p-6 border-b border-gray-200">
      <h3 class="text-sm font-medium text-gray-900 mb-4">Historial de Respuestas (<%= @support_ticket.reply_count %>)</h3>
      
      <% if @support_ticket.ticket_replies.any? %>
        <div class="space-y-4">
          <% @support_ticket.ticket_replies.order(:created_at).each do |reply| %>
            <div class="flex items-start space-x-3">
              <div class="flex-shrink-0">
                <div class="h-10 w-10 rounded-full bg-indigo-100 flex items-center justify-center">
                  <span class="text-indigo-600 font-medium"><%= reply.user.email.first.upcase %></span>
                </div>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center space-x-2 mb-1">
                  <span class="text-sm font-medium text-gray-900"><%= reply.user.email %></span>
                  <% if reply.user.admin? %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-purple-100 text-purple-800">Admin</span>
                  <% end %>
                  <span class="text-xs text-gray-500"><%= reply.created_at.strftime('%d/%m/%Y %H:%M') %></span>
                </div>
                <div class="bg-gray-50 rounded-lg p-3">
                  <p class="text-sm text-gray-700 whitespace-pre-wrap"><%= reply.message %></p>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-gray-500">No hay respuestas aún.</p>
      <% end %>
    </div>

    <!-- Reply Form -->
    <div class="px-4 py-5 sm:p-6 bg-gray-50">
      <h3 class="text-sm font-medium text-gray-900 mb-3">Responder</h3>
      <%= form_with(model: @ticket_reply, url: create_reply_admin_support_ticket_path(@support_ticket), method: :post, local: true, class: "space-y-4") do |form| %>
        <div>
          <%= form.text_area :message, rows: 4, class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md", placeholder: "Escribe tu respuesta..." %>
        </div>
        <div class="flex justify-end">
          <%= form.submit "Enviar Respuesta", class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
