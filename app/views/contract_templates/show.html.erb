<div class="mb-6">
  <%= link_to "← Volver a plantillas", contract_templates_path, class: "text-sm text-indigo-600 hover:text-indigo-800" %>
</div>

<div class="bg-white rounded-lg shadow-sm border border-gray-200 p-8">
  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800">
    <%= @template.category %>
  </span>
  <h1 class="mt-3 text-2xl font-bold text-gray-900"><%= @template.name %></h1>
  <p class="mt-2 text-gray-600"><%= @template.description %></p>

  <div class="mt-6">
    <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wide">Campos requeridos</h2>
    <div class="mt-2 flex flex-wrap gap-2">
      <% @template.placeholders.each do |placeholder| %>
        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-gray-100 text-gray-700">
          <%= @template.label_for(placeholder) %>
        </span>
      <% end %>
    </div>
  </div>

  <div class="mt-6">
    <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wide">Vista previa de la plantilla</h2>
    <div class="mt-2 bg-gray-50 rounded-md p-4 text-sm text-gray-600 whitespace-pre-wrap font-mono"><%= @template.body %></div>
  </div>

  <div class="mt-8">
    <%= link_to "Usar esta plantilla", new_contract_path(template_id: @template.id), class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-md hover:bg-indigo-700" %>
  </div>
</div>
