<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Header -->
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-6">
    <div class="flex items-center justify-between">
      <div class="flex items-center space-x-4">
        <% if @company.logo.attached? %>
          <%= image_tag @company.logo, class: "h-16 w-16 rounded-lg object-cover" %>
        <% else %>
          <div class="h-16 w-16 bg-gray-200 rounded-lg flex items-center justify-center">
            <svg class="h-8 w-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
        <% end %>
        <div>
          <h1 class="text-2xl font-bold text-gray-900"><%= @company.name %></h1>
          <p class="text-sm text-gray-500">Plan Business</p>
        </div>
      </div>
      <%= link_to "Editar Empresa", edit_company_path(@company), class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50" %>
    </div>
  </div>

  <!-- Navigation Tabs -->
  <div class="border-b border-gray-200 mb-6">
    <nav class="flex space-x-8">
      <a href="#team" class="border-indigo-500 text-indigo-600 whitespace-nowrap py-2 px-1 border-b-2 font-medium text-sm">Equipo</a>
      <a href="#templates" class="border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-2 px-1 border-b-2 font-medium text-sm">Plantillas</a>
      <a href="#support" class="border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-2 px-1 border-b-2 font-medium text-sm">Soporte</a>
    </nav>
  </div>

  <!-- Team Section -->
  <div id="team" class="mb-8">
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-medium text-gray-900">Miembros del Equipo</h2>
        <button class="inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded-full text-indigo-700 bg-indigo-100 hover:bg-indigo-200">
          Invitar Miembro
        </button>
      </div>
      
      <div class="space-y-3">
        <% @company_users.each do |company_user| %>
          <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
            <div class="flex items-center space-x-3">
              <div class="h-10 w-10 bg-indigo-100 rounded-full flex items-center justify-center">
                <span class="text-sm font-medium text-indigo-600">
                  <%= company_user.user.email.first.upcase %>
                </span>
              </div>
              <div>
                <p class="text-sm font-medium text-gray-900"><%= company_user.user.email %></p>
                <p class="text-xs text-gray-500">
                  <% if company_user.owner? %>
                    Owner
                  <% elsif company_user.admin? %>
                    Admin
                  <% else %>
                    Miembro
                  <% end %>
                </p>
              </div>
            </div>
            <div class="flex items-center space-x-2">
              <% if company_user.owner? %>
                <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                  Dueño
                </span>
              <% end %>
              <% unless company_user.owner? %>
                <button class="text-red-600 hover:text-red-800 text-sm">Eliminar</button>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Templates Section -->
  <div id="templates" class="mb-8">
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-medium text-gray-900">Plantillas Personalizadas</h2>
        <%= link_to "Nueva Plantilla", new_custom_template_path, class: "inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded-full text-indigo-700 bg-indigo-100 hover:bg-indigo-200" %>
      </div>
      
      <% if @custom_templates.any? %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          <% @custom_templates.each do |template| %>
            <div class="border border-gray-200 rounded-lg p-4 hover:shadow-md transition-shadow">
              <h3 class="font-medium text-gray-900 mb-2"><%= template.name %></h3>
              <p class="text-sm text-gray-500 mb-3"><%= template.description %></p>
              <div class="flex items-center justify-between">
                <span class="text-xs text-gray-400">Basado en: <%= template.contract_template.name %></span>
                <div class="flex space-x-2">
                  <%= link_to "Editar", edit_custom_template_path(template), class: "text-indigo-600 hover:text-indigo-800 text-xs" %>
                  <%= link_to "Usar", new_contract_path(custom_template_id: template.id), class: "text-green-600 hover:text-green-800 text-xs" %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-8">
          <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          <h3 class="mt-2 text-sm font-medium text-gray-900">No hay plantillas personalizadas</h3>
          <p class="mt-1 text-sm text-gray-500">Crea tu primera plantilla personalizada para tu equipo.</p>
          <div class="mt-6">
            <%= link_to "Crear Plantilla", new_custom_template_path, class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Support Section -->
  <div id="support" class="mb-8">
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-medium text-gray-900">Tickets de Soporte</h2>
        <%= link_to "Nuevo Ticket", new_support_ticket_path, class: "inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded-full text-indigo-700 bg-indigo-100 hover:bg-indigo-200" %>
      </div>
      
      <div class="space-y-3">
        <% current_user.support_tickets.limit(5).each do |ticket| %>
          <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
            <div class="flex-1">
              <p class="text-sm font-medium text-gray-900"><%= ticket.subject %></p>
              <p class="text-xs text-gray-500">Creado: <%= ticket.created_at.strftime('%d/%m/%Y %H:%M') %></p>
            </div>
            <div class="flex items-center space-x-2">
              <% priority_class = case ticket.priority
                              when 'urgent' then 'bg-red-100 text-red-800'
                              when 'high' then 'bg-orange-100 text-orange-800'
                              when 'normal' then 'bg-blue-100 text-blue-800'
                              else 'bg-gray-100 text-gray-800'
                              end %>
              <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium <%= priority_class %>">
                <%= ticket.priority.upcase %>
              </span>
              
              <% status_class = case ticket.status
                             when 'open' then 'bg-green-100 text-green-800'
                             when 'in_progress' then 'bg-yellow-100 text-yellow-800'
                             when 'resolved' then 'bg-blue-100 text-blue-800'
                             else 'bg-gray-100 text-gray-800'
                             end %>
              <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium <%= status_class %>">
                <%= ticket.status.gsub('_', ' ').upcase %>
              </span>
            </div>
          </div>
        <% end %>
      </div>
      
      <% if current_user.support_tickets.count > 5 %>
        <div class="mt-4 text-center">
          <%= link_to "Ver Todos los Tickets", support_tickets_path, class: "text-indigo-600 hover:text-indigo-800 text-sm" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
